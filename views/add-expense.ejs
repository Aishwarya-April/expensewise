<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Transaction - ExpenseWise</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">
            <i class="fas fa-wallet me-2"></i>ExpenseWise
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item">
                    <a class="nav-link" href="/dashboard">
                        <i class="fas fa-chart-pie me-1"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/expenses/add">
                        <i class="fas fa-plus-circle me-1"></i>Add Transaction
                    </a>
                </li>
                <li class="nav-item ms-2">
                    <a class="btn btn-sm" href="/logout"
                    style="background:#e74c3c; color:white; border-radius:20px; padding:6px 16px;">
                        <i class="fas fa-sign-out-alt me-1"></i>Logout
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<section class="dashboard-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="auth-card">

                    <h4 class="fw-bold mb-1">
                        <i class="fas fa-plus-circle me-2" style="color:#00d4aa"></i>
                        Add Transaction
                    </h4>
                    <p class="text-muted mb-4">Record your income or expense</p>

                    <% if (error) { %>
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                        </div>
                    <% } %>

                    <form action="/expenses/add" method="POST">

                        <!-- Title -->
                        <div class="mb-3">
                            <label class="form-label fw-500">Title</label>
                            <input type="text" class="form-control" name="title" 
                                   placeholder="e.g. Monthly Salary, Grocery Shopping" required>
                        </div>

                        <!-- Amount -->
                        <div class="mb-3">
                            <label class="form-label fw-500">Amount (₹)</label>
                            <input type="number" class="form-control" name="amount" 
                                   placeholder="Enter amount" min="0" step="0.01" required>
                        </div>

                        <!-- Type -->
                        <div class="mb-3">
                            <label class="form-label fw-500">Type</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" 
                                           name="type" value="income" id="income" required>
                                    <label class="form-check-label text-success fw-500" for="income">
                                        <i class="fas fa-arrow-up me-1"></i>Income
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" 
                                           name="type" value="expense" id="expense">
                                    <label class="form-check-label text-danger fw-500" for="expense">
                                        <i class="fas fa-arrow-down me-1"></i>Expense
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Category -->
                        <div class="mb-3">
                            <label class="form-label fw-500">Category</label>
                            <select class="form-select" name="category" required>
                                <option value="">Select category</option>
                                <option value="Salary">💼 Salary</option>
                                <option value="Food">🍔 Food</option>
                                <option value="Transport">🚗 Transport</option>
                                <option value="Shopping">🛍️ Shopping</option>
                                <option value="Entertainment">🎮 Entertainment</option>
                                <option value="Health">🏥 Health</option>
                                <option value="Education">📚 Education</option>
                                <option value="Other">📦 Other</option>
                            </select>
                        </div>

                        <!-- Date -->
                        <div class="mb-3">
                            <label class="form-label fw-500">Date</label>
                            <input type="date" class="form-control" name="date">
                        </div>

                        <!-- Note -->
                        <div class="mb-4">
                            <label class="form-label fw-500">Note (Optional)</label>
                            <textarea class="form-control" name="note" rows="2" 
                                      placeholder="Any additional notes..."></textarea>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary flex-fill py-2">
                                <i class="fas fa-save me-2"></i>Save Transaction
                            </button>
                            <a href="/dashboard" class="btn btn-outline-secondary flex-fill py-2">
                                Cancel
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>