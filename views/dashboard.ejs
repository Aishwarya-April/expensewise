<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - ExpenseWise</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">
            <i class="fas fa-wallet me-2"></i>ExpenseWise
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item">
                    <a class="nav-link" href="/dashboard">
                        <i class="fas fa-chart-pie me-1"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/expenses/add">
                        <i class="fas fa-plus-circle me-1"></i>Add Transaction
                    </a>
                </li>
                <li class="nav-item ms-2">
                    <button class="btn btn-sm" id="darkModeToggle" style="background:#2c3e50; color:white; border-radius:20px; padding: 6px 16px;">
                        <i class="fas fa-moon me-1"></i>Dark
                    </button>
                </li>
                <li class="nav-item ms-2">
                    <a class="btn btn-sm" href="/logout" 
                    style="background:#e74c3c; color:white; border-radius:20px; padding: 6px 16px;">
                        <i class="fas fa-sign-out-alt me-1"></i>Logout
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<section class="dashboard-section">
    <div class="container">

        <!-- Welcome -->
        <div class="mb-4">
            <h3 class="fw-bold">Welcome back, <%= (user && user.name) || 'User' %>! 👋</h3>
            <p class="text-muted">Here's your financial summary</p>
        </div>

        <!-- STAT CARDS -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="stat-card balance">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Total Balance</div>
                            <div class="stat-amount">₹<%= (typeof balance === 'number' ? balance.toFixed(2) : '0.00') %></div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-wallet"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card income">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Total Income</div>
                            <div class="stat-amount">₹<%= (typeof totalIncome === 'number' ? totalIncome.toFixed(2) : '0.00') %></div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-arrow-circle-up"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card expense">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Total Expenses</div>
                            <div class="stat-amount">₹<%= (typeof totalExpense === 'number' ? totalExpense.toFixed(2) : '0.00') %></div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-arrow-circle-down"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- TRANSACTIONS LIST -->
            <div class="col-md-8">
                <div class="transaction-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0">Recent Transactions</h5>
                        <div>
                            <select class="form-select form-select-sm d-inline-block w-auto me-2" id="categoryFilter" style="max-width: 150px;">
                                <option value="">All Categories</option>
                                <option value="Food">Food</option>
                                <option value="Transport">Transport</option>
                                <option value="Shopping">Shopping</option>
                                <option value="Entertainment">Entertainment</option>
                                <option value="Health">Health</option>
                                <option value="Education">Education</option>
                                <option value="Salary">Salary</option>
                                <option value="Other">Other</option>
                            </select>
                            <a href="javascript:exportCSV()" class="btn btn-sm btn-secondary me-2" title="Export to CSV">
                                <i class="fas fa-download me-1"></i>Export
                            </a>
                            <a href="/expenses/add" class="btn btn-sm btn-primary">
                                <i class="fas fa-plus me-1"></i>Add New
                            </a>
                        </div>
                    </div>

                    <div id="transactionList">
                        <% if (!expenses || expenses.length === 0) { %>
                            <div class="text-center py-5 text-muted">
                                <i class="fas fa-receipt fa-3x mb-3"></i>
                                <p>No transactions yet. Add your first one!</p>
                                <a href="/expenses/add" class="btn btn-primary">
                                    <i class="fas fa-plus me-1"></i>Add Transaction
                                </a>
                            </div>
                        <% } else { %>
                            <% (expenses || []).slice(0, 10).forEach(exp => { %>
                                <div class="transaction-item" data-category="<%= exp.category %>">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3" style="width:40px; height:40px; border-radius:50%; background:<%= exp.type === 'income' ? '#e8faf5' : '#fde8e8' %>; display:flex; align-items:center; justify-content:center;">
                                            <i class="fas <%= exp.type === 'income' ? 'fa-arrow-up' : 'fa-arrow-down' %>" style="color:<%= exp.type === 'income' ? '#00d4aa' : '#e74c3c' %>"></i>
                                        </div>
                                        <div>
                                            <div class="fw-500"><%= exp.title || '' %></div>
                                            <small class="text-muted"><%= (exp.category || '') %> • <%= new Date(exp.date || Date.now()).toLocaleDateString() %></small>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center">
                                            <span class="<%= (exp && exp.type) === 'income' ? 'amount-income' : 'amount-expense' %> me-3">
                                            <%= (exp && exp.type) === 'income' ? '+' : '-' %>₹<%= (exp && typeof exp.amount === 'number' ? exp.amount.toFixed(2) : '0.00') %>
                                        </span>
                                        <a href="/expenses/delete/<%= exp._id %>" 
                                           onclick="return confirm('Delete this transaction?')"
                                           class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- ANALYTICS & CONVERTER -->
            <div class="col-md-4">
                <!-- Charts -->
                <div class="converter-card mb-4">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-chart-pie me-2"></i>Expense Breakdown
                    </h5>
                    <canvas id="categoryChart" style="max-height: 250px;"></canvas>
                </div>

                <!-- CURRENCY CONVERTER -->
                <div class="converter-card">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-exchange-alt me-2"></i>Currency Converter
                    </h5>
                    <div class="mb-3">
                        <label class="form-label text-white-50">Amount (₹)</label>
                        <input type="number" class="form-control" id="convertAmount" 
                               placeholder="Enter amount" value="1000">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white-50">Convert To</label>
                        <select class="form-select" id="targetCurrency">
                            <!-- Americas -->
                            <optgroup label="🌎 Americas">
                                <option value="USD">🇺🇸 USD - US Dollar</option>
                                <option value="CAD">🇨🇦 CAD - Canadian Dollar</option>
                                <option value="MXN">🇲🇽 MXN - Mexican Peso</option>
                                <option value="BRL">🇧🇷 BRL - Brazilian Real</option>
                                <option value="ARS">🇦🇷 ARS - Argentine Peso</option>
                                <option value="CLP">🇨🇱 CLP - Chilean Peso</option>
                            </optgroup>
                            
                            <!-- Europe -->
                            <optgroup label="🌍 Europe">
                                <option value="EUR">🇪🇺 EUR - Euro</option>
                                <option value="GBP">🇬🇧 GBP - British Pound</option>
                                <option value="CHF">🇨🇭 CHF - Swiss Franc</option>
                                <option value="SEK">🇸🇪 SEK - Swedish Krona</option>
                                <option value="NOK">🇳🇴 NOK - Norwegian Krone</option>
                                <option value="DKK">🇩🇰 DKK - Danish Krone</option>
                                <option value="PLN">🇵🇱 PLN - Polish Zloty</option>
                                <option value="CZK">🇨🇿 CZK - Czech Koruna</option>
                                <option value="HUF">🇭🇺 HUF - Hungarian Forint</option>
                                <option value="RON">🇷🇴 RON - Romanian Leu</option>
                                <option value="BGN">🇧🇬 BGN - Bulgarian Lev</option>
                                <option value="HRK">🇭🇷 HRK - Croatian Kuna</option>
                                <option value="RUB">🇷🇺 RUB - Russian Ruble</option>
                                <option value="UAH">🇺🇦 UAH - Ukrainian Hryvnia</option>
                                <option value="GEL">🇬🇪 GEL - Georgian Lari</option>
                            </optgroup>
                            
                            <!-- Asia-Pacific -->
                            <optgroup label="🌏 Asia-Pacific">
                                <option value="JPY">🇯🇵 JPY - Japanese Yen</option>
                                <option value="CNY">🇨🇳 CNY - Chinese Yuan</option>
                                <option value="KRW">🇰🇷 KRW - Korean Won</option>
                                <option value="TWD">🇹🇼 TWD - Taiwan Dollar</option>
                                <option value="HKD">🇭🇰 HKD - Hong Kong Dollar</option>
                                <option value="SGD">🇸🇬 SGD - Singapore Dollar</option>
                                <option value="MYR">🇲🇾 MYR - Malaysian Ringgit</option>
                                <option value="THB">🇹🇭 THB - Thai Baht</option>
                                <option value="IDR">🇮🇩 IDR - Indonesian Rupiah</option>
                                <option value="PHP">🇵🇭 PHP - Philippine Peso</option>
                                <option value="VND">🇻🇳 VND - Vietnamese Dong</option>
                                <option value="AUD">🇦🇺 AUD - Australian Dollar</option>
                                <option value="NZD">🇳🇿 NZD - New Zealand Dollar</option>
                                <option value="PKR">🇵🇰 PKR - Pakistani Rupee</option>
                                <option value="BDT">🇧🇩 BDT - Bangladeshi Taka</option>
                                <option value="LKR">🇱🇰 LKR - Sri Lankan Rupee</option>
                                <option value="MMK">🇲🇲 MMK - Myanmar Kyat</option>
                            </optgroup>
                            
                            <!-- Middle East & Africa -->
                            <optgroup label="🌍 Middle East & Africa">
                                <option value="SAR">🇸🇦 SAR - Saudi Riyal</option>
                                <option value="AED">🇦🇪 AED - UAE Dirham</option>
                                <option value="QAR">🇶🇦 QAR - Qatari Riyal</option>
                                <option value="KWD">🇰🇼 KWD - Kuwaiti Dinar</option>
                                <option value="BHD">🇧🇭 BHD - Bahraini Dinar</option>
                                <option value="OMR">🇴🇲 OMR - Omani Rial</option>
                                <option value="JOD">🇯🇴 JOD - Jordanian Dinar</option>
                                <option value="ILS">🇮🇱 ILS - Israeli Shekel</option>
                                <option value="EGP">🇪🇬 EGP - Egyptian Pound</option>
                                <option value="ZAR">🇿🇦 ZAR - South African Rand</option>
                                <option value="NGN">🇳🇬 NGN - Nigerian Naira</option>
                                <option value="KES">🇰🇪 KES - Kenyan Shilling</option>
                                <option value="GHS">🇬🇭 GHS - Ghanaian Cedi</option>
                            </optgroup>
                        </select>
                    </div>
                    <button class="btn btn-primary w-100" onclick="convertCurrency()">
                        <i class="fas fa-sync me-2"></i>Convert
                    </button>
                    <div id="convertResult" class="mt-3 text-center" style="font-size:1.3rem; font-weight:600; color:#00d4aa"></div>
                    <div id="convertError" class="mt-2 text-danger text-center" style="font-size:0.85rem"></div>
                </div>
            </div>
        </div>

    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/darkmode.js"></script>
<script src="/js/main.js"></script>
<script>
    document.getElementById('categoryFilter').addEventListener('change', function(e) {
        const category = e.target.value;
        const items = document.querySelectorAll('.transaction-item');
        items.forEach(item => {
            if (!category) {
                item.style.display = 'flex';
            } else {
                const itemCategory = item.getAttribute('data-category');
                item.style.display = itemCategory === category ? 'flex' : 'none';
            }
        });
    });

    // CSV Export
    function exportCSV() {
        const expenses = <%= JSON.stringify(expenses) %>;
        const user = '<%= user.name %>';
        
        let csv = 'Title,Amount,Type,Category,Date,Note\n';
        expenses.forEach(exp => {
            const date = new Date(exp.date).toLocaleDateString();
            csv += `"${exp.title}","${exp.amount}","${exp.type}","${exp.category}","${date}","${exp.note || ''}"\n`;
        });
        
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `expenses-${new Date().toISOString().split('T')[0]}.csv`;
        a.click();
    }

    // Chart.js - Expense Breakdown by Category
    const expenses = <%= JSON.stringify(expenses) %>;
    const categoryData = {};
    
    expenses.forEach(exp => {
        if (exp.type === 'expense') {
            categoryData[exp.category] = (categoryData[exp.category] || 0) + exp.amount;
        }
    });
    
    if (Object.keys(categoryData).length > 0) {
        const ctx = document.getElementById('categoryChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: Object.keys(categoryData),
                datasets: [{
                    data: Object.values(categoryData),
                    backgroundColor: [
                        '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0',
                        '#9966FF', '#FF9F40', '#FF6384', '#C9CBCF'
                    ],
                    borderColor: '#fff',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { font: { size: 12 }, padding: 10 }
                    }
                }
            }
        });
    }

    async function convertCurrency() {
        const amount = document.getElementById('convertAmount').value;
        const currency = document.getElementById('targetCurrency').value;
        const resultDiv = document.getElementById('convertResult');
        const errorDiv = document.getElementById('convertError');

        resultDiv.textContent = 'Converting...';
        errorDiv.textContent = '';

        try {
            const response = await fetch(`/api/convert?amount=${amount}&to=${currency}`);
            const data = await response.json();

            if (data.success) {
                resultDiv.textContent = `₹${amount} = ${data.converted} ${currency}`;
            } else {
                errorDiv.textContent = data.message || 'Conversion failed';
                resultDiv.textContent = '';
            }
        } catch (err) {
            errorDiv.textContent = 'Could not connect. Try again.';
            resultDiv.textContent = '';
        }
    }
</script>
</body>
</html>