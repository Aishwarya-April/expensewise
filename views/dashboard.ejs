<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - ExpenseWise</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Chart.js not needed on main dashboard (moved to Analytics page) -->
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">
            <i class="fas fa-wallet me-2"></i>ExpenseWise
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item">
                    <a class="nav-link" href="/dashboard">
                        <i class="fas fa-chart-pie me-1"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/analytics">
                        <i class="fas fa-chart-bar me-1"></i>Analytics
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/converter">
                        <i class="fas fa-exchange-alt me-1"></i>Converter
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/expenses/add">
                        <i class="fas fa-plus-circle me-1"></i>Add
                    </a>
                </li>
                <li class="nav-item ms-2">
                    <button class="btn btn-sm" id="darkModeToggle" style="background:#2c3e50; color:white; border-radius:20px; padding: 6px 16px;">
                        <i class="fas fa-moon me-1"></i>Dark
                    </button>
                </li>
                <li class="nav-item ms-2">
                    <a class="btn btn-sm" href="/logout" 
                    style="background:#e74c3c; color:white; border-radius:20px; padding: 6px 16px;">
                        <i class="fas fa-sign-out-alt me-1"></i>Logout
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<section class="dashboard-section">
    <div class="container">

        <!-- Welcome -->
        <div class="mb-4">
            <h3 class="fw-bold">Welcome back, <%= (user && user.name) || 'User' %>! 👋</h3>
            <p class="text-muted">Here's your financial summary</p>
        </div>

        <!-- STAT CARDS -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="stat-card balance">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Total Balance</div>
                            <div class="stat-amount">₹0.00</div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-wallet"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card income">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Total Income</div>
                            <div class="stat-amount">₹0.00</div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-arrow-circle-up"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card expense">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-label">Total Expenses</div>
                            <div class="stat-amount">₹0.00</div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-arrow-circle-down"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- TRANSACTIONS LIST -->
            <div class="col-md-8">
                <div class="transaction-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0">Recent Transactions</h5>
                        <div>
                            <select class="form-select form-select-sm d-inline-block w-auto me-2" id="categoryFilter" style="max-width: 150px;">
                                <option value="">All Categories</option>
                                <option value="Food">Food</option>
                                <option value="Transport">Transport</option>
                                <option value="Shopping">Shopping</option>
                                <option value="Entertainment">Entertainment</option>
                                <option value="Health">Health</option>
                                <option value="Education">Education</option>
                                <option value="Salary">Salary</option>
                                <option value="Other">Other</option>
                            </select>
                            <a href="javascript:exportCSV()" class="btn btn-sm btn-secondary me-2" title="Export to CSV">
                                <i class="fas fa-download me-1"></i>Export
                            </a>
                            <a href="/expenses/add" class="btn btn-sm btn-primary">
                                <i class="fas fa-plus me-1"></i>Add New
                            </a>
                        </div>
                    </div>

                    <div id="transactionList">
                        <!-- transactions will be rendered by JavaScript -->
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/darkmode.js"></script>
<script src="/js/main.js"></script>
<script>
    // ===== shared state and helpers =====
    let transactions = [];
    let filteredTransactions = [];
    let userPreferredCurrency = '<%= (user && user.preferredCurrency) || "INR" %>';
    
    // Get currency symbol
    function getCurrencySymbol(currencyCode) {
        const symbols = {
            'INR': '₹',
            'USD': '$',
            'EUR': '€',
            'GBP': '£',
            'JPY': '¥',
            'AUD': 'A$',
            'CAD': 'C$',
            'CHF': 'CHF',
            'CNY': '¥',
            'AED': 'د.إ',
            'SGD': 'S$',
            'MYR': 'RM',
            'THB': '฿',
            'PKR': '₨',
            'BDT': '৳',
            'ZAR': 'R',
            'MXN': '$',
            'BRL': 'R$',
            'KRW': '₩',
            'HKD': 'HK$'
        };
        return symbols[currencyCode] || currencyCode;
    }

    function formatAmount(val) {
        const symbol = getCurrencySymbol(userPreferredCurrency);
        return symbol + parseFloat(val).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function calculateTotals(data) {
        let income = 0, expense = 0;
        data.forEach(t => {
            if (t.type === 'income') income += t.amount;
            else expense += t.amount;
        });
        return { totalIncome: income, totalExpense: expense, balance: income - expense };
    }

    function renderTotals() {
        const { totalIncome, totalExpense, balance } = calculateTotals(filteredTransactions.length ? filteredTransactions : transactions);
        document.querySelector('.stat-card.balance .stat-amount').textContent = formatAmount(balance);
        document.querySelector('.stat-card.income .stat-amount').textContent = formatAmount(totalIncome);
        document.querySelector('.stat-card.expense .stat-amount').textContent = formatAmount(totalExpense);
    }

    function renderTransactions() {
        const container = document.getElementById('transactionList');
        const list = (filteredTransactions.length ? filteredTransactions : transactions).slice(0, 10);
        if (!list || list.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-receipt fa-3x mb-3"></i>
                    <p>No transactions yet. Add your first one!</p>
                    <a href="/expenses/add" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>Add Transaction
                    </a>
                </div>`;
            return;
        }
        container.innerHTML = '';
        list.forEach(exp => {
            const dateStr = new Date(exp.date || Date.now()).toLocaleDateString();
            const amountStr = formatAmount(exp.amount);
            const iconClass = exp.type === 'income' ? 'fa-arrow-up' : 'fa-arrow-down';
            const bgColor = exp.type === 'income' ? '#e8faf5' : '#fde8e8';
            const color = exp.type === 'income' ? '#00d4aa' : '#e74c3c';

            const item = document.createElement('div');
            item.className = 'transaction-item';
            item.setAttribute('data-category', exp.category || '');
            item.innerHTML = `
                <div class="d-flex align-items-center">
                    <div class="me-3" style="width:40px; height:40px; border-radius:50%; background:${bgColor}; display:flex; align-items:center; justify-content:center;">
                        <i class="fas ${iconClass}" style="color:${color}"></i>
                    </div>
                    <div>
                        <div class="fw-500">${exp.title || ''}</div>
                        <small class="text-muted">${exp.category || ''} • ${dateStr}</small>
                    </div>
                </div>
                <div class="d-flex align-items-center">
                    <span class="${exp.type === 'income' ? 'amount-income' : 'amount-expense'} me-3">
                        ${(exp.type === 'income' ? '+' : '-')}${amountStr}
                    </span>
                    <button onclick="deleteTransaction('${exp._id}')" class="btn btn-sm btn-outline-danger">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>`;
            container.appendChild(item);
        });
    }

    function applyFilter(category) {
        if (!category) {
            filteredTransactions = [];
        } else {
            filteredTransactions = transactions.filter(t => t.category === category);
        }
        renderTotals();
        renderTransactions();
    }

    document.getElementById('categoryFilter').addEventListener('change', function(e) {
        applyFilter(e.target.value);
    });

    // CSV Export that respects current view
    function exportCSV() {
        const data = filteredTransactions.length ? filteredTransactions : transactions;
        let csv = 'Title,Amount (' + userPreferredCurrency + '),Type,Category,Date,Note\n';
        data.forEach(exp => {
            const date = new Date(exp.date).toLocaleDateString();
            const amount = parseFloat(exp.amount).toFixed(2);
            csv += `"${exp.title}","${amount}","${exp.type}","${exp.category}","${date}","${exp.note || ''}"\n`;
        });
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `transactions-${new Date().toISOString().split('T')[0]}.csv`;
        a.click();
    }

    async function deleteTransaction(id) {
        if (!confirm('Delete this transaction?')) return;
        try {
            const resp = await fetch(`/api/expenses/${id}`, { method: 'DELETE' });
            const json = await resp.json();
            if (json.success) {
                transactions = transactions.filter(t => t._id !== id);
                applyFilter(document.getElementById('categoryFilter').value);
            } else {
                alert(json.message || 'Failed to delete');
            }
        } catch (err) {
            console.error('Delete error', err);
            alert('Unable to delete');
        }
    }

    // Fetch transactions from server
    async function refreshData() {
        try {
            const resp = await fetch('/api/expenses');
            const json = await resp.json();
            if (json.success) {
                transactions = json.expenses;
                applyFilter(document.getElementById('categoryFilter').value);
            }
        } catch (err) {
            console.error('Error fetching transactions:', err);
        }
    }

    // Initialize
    (async function init() {
        applyFilter('');
        renderTotals();
        renderTransactions();
        refreshData();
    })();
</script>
</body>
</html>